# Mattermost
MATTERMOST_URL=https://chat.example.com
MATTERMOST_PORT=443
MATTERMOST_TEAM=myteam
MATTERMOST_BOT_TOKEN=REPLACE_ME
MATTERMOST_BOT_USERNAME=ops-agent
MATTERMOST_THREAD_REPLIES=true  # true: thread-scoped context; false: channel+user scope

# Kubernetes
K8S_NAMESPACE=sandbox
K8S_MODE=incluster          # incluster | kubeconfig
K8S_KUBECONFIG_PATH=        # only for K8S_MODE=kubeconfig
K8S_NAME_SECRET=REPLACE_WITH_RANDOM_SECRET

# OpenAI-compatible model (forwarded to every ZeroClaw pod)
OPENAI_API_KEY=REPLACE_ME
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

WEBHOOK_HOST_PORT=8579
WEBHOOK_PUBLIC_URL=http://host.orb.internal:8579

# ZeroClaw pods
ZEROCLAW_IMAGE=ghcr.io/zeroclaw-labs/zeroclaw:latest
ZEROCLAW_PORT=42617
ZEROCLAW_CPU_REQUEST=500m
ZEROCLAW_CPU_LIMIT=2
ZEROCLAW_MEMORY_REQUEST=1Gi
ZEROCLAW_MEMORY_LIMIT=4Gi

# User storage
USER_PVC_SIZE=5Gi
USER_PVC_STORAGE_CLASS=     # leave empty for cluster default

# Lifecycle
IDLE_TIMEOUT_SECONDS=3600
POD_READY_TIMEOUT_SECONDS=120
REAPER_INTERVAL_SECONDS=60

LOG_LEVEL=20
SSL_VERIFY=false
